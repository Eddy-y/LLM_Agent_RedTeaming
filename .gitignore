# ==========================================
# Python Environments
# ==========================================
# Ignore virtual environment directories to prevent committing massive dependency folders
*venv/
*.venv/
venv*
.venv*

# ==========================================
# Secrets & Configuration
# ==========================================
# Ignore environment variables and local configurations to prevent leaking API keys
.env
.env*

# ==========================================
# Python Cache & Compiled Files
# ==========================================
# Ignore compiled byte-code and cache directories that Python generates automatically
*.pyc
*.pyo
*.pyd
__pycache__/*
*__pycache__
**/__pycache__/

# ==========================================
# Data & Databases
# ==========================================
# Ignore local databases and generated data/logs
*.sqlite
*.db
data/
data/raw/
data/agent_summary.csv
data/evaluation_results.jsonl
data/audit_logs.jsonl

# ==========================================
# AWS Serverless Application Model (SAM)
# ==========================================
# Ignore AWS SAM build artifacts and local deployment configurations
.aws-sam/
.sam-cfg.json

# ==========================================
# Lambda Dependencies
# ==========================================
# Ignore Lambda layer build artifacts (regenerated by sam build)
cti_dependencies/python/

# ==========================================
# Documentation (Optional - keep working docs, ignore redundant)
# ==========================================
# Uncomment to ignore redundant documentation files
# GRAPHRAG_IMPLEMENTATION_SUMMARY.md

# ==========================================
# IDE & OS Files
# ==========================================
# macOS metadata
.DS_Store
.AppleDouble
.LSOverride

# Windows metadata
Thumbs.db
ehthumbs.db
Desktop.ini

# VS Code
.vscode/
*.code-workspace

# PyCharm
.idea/
*.iml

# ==========================================
# Testing & Coverage
# ==========================================
.pytest_cache/
.coverage
htmlcov/
*.cover
.hypothesis/

# ==========================================
# Logs
# ==========================================
*.log
logs/
pip-log.txt

# ==========================================
# Temporary Files
# ==========================================
*.tmp
*.bak
*.swp
*~
Figures/
generate_plots.py